			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_Sink_AKV_Parquet'"
		},
		"LS_SqlTable_Parquet1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SqlTable_Parquet1'"
		},
		"SqlServer1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServer1'"
		},
